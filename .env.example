# Database
DATABASE_URL="postgresql://user:password@localhost:5432/lux_door_db"

# NextAuth
NEXTAUTH_SECRET="your-super-secret-key-change-in-production"
NEXTAUTH_URL="http://localhost:3001"

# Cloudinary
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME="your_cloudinary_cloud_name"
CLOUDINARY_API_KEY="your_cloudinary_api_key"
CLOUDINARY_API_SECRET="your_cloudinary_api_secret"

# Frontend URL (for CORS)
NEXT_PUBLIC_FRONTEND_URL="http://localhost:3000"

# Admin Email (optional)
ADMIN_EMAIL="admin@luxdoor.com"

# SuperAdmin Credentials (for database seeding)
NEXTAUTH_SUPERADMIN_USERNAME="change_this_username"
NEXTAUTH_SUPERADMIN_PASSWORD="change_this_password_to_secure"
